{
  "name": "echo-island-backend",
  "version": "1.0.0",
  "description": "Echo Island social resonance mini program backend",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "seed": "node seed/init.js",
    "test": "jest --forceExit --detectOpenHandles --runInBand",
    "test:unit": "jest tests/unit --forceExit --detectOpenHandles --runInBand",
    "test:integration": "jest tests/integration --forceExit --detectOpenHandles --runInBand",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles --runInBand",
    "test:watch": "jest --watchAll --forceExit --detectOpenHandles",
    "env:check": "node scripts/check-env.js",
    "health:check": "node scripts/healthcheck.js",
    "wait:db": "node scripts/wait-for-mongo.js",
    "start:prod": "node scripts/check-env.js && node src/app.js",
    "start:with-seed": "npm run wait:db && npm run seed && npm run start"
  },
  "engines": {
    "node": ">=18.17.0 <21",
    "npm": ">=9"
  },
  "dependencies": {
    "bcryptjs": "3.0.3",
    "cors": "2.8.6",
    "dotenv": "16.6.1",
    "express": "4.22.2",
    "express-validator": "7.3.2",
    "jsonwebtoken": "9.0.3",
    "mongoose": "8.24.0",
    "multer": "1.4.5-lts.2",
    "winston": "3.19.0",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "supertest": "7.2.2",
    "mongodb-memory-server": "9.5.0",
    "nodemon": "3.1.14"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 60000,
    "maxWorkers": 1,
    "verbose": true,
    "globalSetup": null,
    "globalTeardown": null
  }
}
