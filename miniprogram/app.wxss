page {
  min-height: 100%;
  background: radial-gradient(circle at top, #e5f4fb 0%, #f4fafc 45%, #ffffff 100%);
  color: #1f3a48;
  font-size: 28rpx;
  line-height: 1.6;
  font-family: Georgia, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.ocean-card {
  background: linear-gradient(150deg, rgba(255, 255, 255, 0.98) 0%, rgba(242, 249, 253, 0.98) 100%);
  border: 2rpx solid rgba(129, 182, 206, 0.25);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(7, 56, 76, 0.08);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.hero-card {
  background: linear-gradient(135deg, #0d3c52 0%, #0b5770 55%, #3b8fb0 100%);
  color: #eaf8ff;
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 20rpx 40rpx rgba(13, 60, 82, 0.22);
}

.hero-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  opacity: 0.92;
}

button {
  border: none;
  text-align: center;
  font-size: 28rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.btn-primary {
  background: linear-gradient(135deg, #0b6585 0%, #0a8ab5 100%);
  color: #ffffff;
  font-weight: 600;
  height: 86rpx;
  line-height: 86rpx;
}

.btn-secondary {
  background: #eef6fa;
  color: #0d4f69;
  height: 86rpx;
  line-height: 86rpx;
}

.btn-danger {
  background: #fff1f0;
  color: #e74c3c;
  height: 86rpx;
  line-height: 86rpx;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid #c9e1ec;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1f3a48;
  font-size: 28rpx;
}

.input {
  display: block;
  height: 86rpx;
  line-height: 86rpx;
  padding: 0 20rpx;
}

.textarea {
  padding: 20rpx;
  min-height: 220rpx;
  line-height: 1.6;
}

.row > .input {
  width: 0;
  flex: 1;
  min-width: 0;
}

.muted {
  color: #6e8794;
}

.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.wrap {
  display: flex;
  flex-wrap: wrap;
}

.tag-chip {
  background: #eaf5fb;
  color: #0f5977;
  border: 2rpx solid #b7d8e7;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
}

.tag-chip.active {
  background: #0c5f7f;
  color: #ffffff;
  border-color: #0c5f7f;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-item {
  border-radius: 18rpx;
  background: #ffffff;
  padding: 18rpx;
  border: 2rpx solid #d7e9f1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #0f5f7c;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty {
  text-align: center;
  color: #7f9ba8;
  padding: 72rpx 20rpx;
}

.mt-12 { margin-top: 12rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-24 { margin-bottom: 24rpx; }
