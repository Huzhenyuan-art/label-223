.login-container {
  min-height: 100vh;
  box-sizing: border-box;
}

.form-card {
  margin-bottom: 20rpx;
}

.error-banner {
  background: #fff1f0;
  color: #e74c3c;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  text-align: center;
}

.mode-switch {
  display: flex;
  padding: 8rpx;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  background: #eef6fa;
}

.mode-pill {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 16rpx;
  color: #6e8794;
  font-weight: 600;
}

.mode-pill.active {
  background: #ffffff;
  color: #0d4f69;
  box-shadow: 0 8rpx 18rpx rgba(13, 60, 82, 0.08);
}

.form-tip {
  margin-top: -4rpx;
  margin-bottom: 20rpx;
}

.form-note {
  margin-top: 18rpx;
  color: #6e8794;
  font-size: 24rpx;
  line-height: 1.7;
}
