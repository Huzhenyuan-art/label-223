.page {
  min-height: 100vh;
  background-color: #F3F4F6;
  padding-bottom: 140rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #F3F4F6;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #1F2937;
}

.search-btn {
  color: #0a5d7b;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 8rpx;
  white-space: nowrap;
}

.tag-filter {
  background: #FFFFFF;
  padding: 0 24rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tag-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-chip {
  display: inline-block;
  background: #eaf5fb;
  color: #0f5977;
  border: 2rpx solid #b7d8e7;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
  margin-right: 12rpx;
  font-size: 24rpx;
}

.filter-chip.active {
  background: #0c5f7f;
  color: #ffffff;
  border-color: #0c5f7f;
}

.clear-filter {
  font-size: 24rpx;
  color: #EF4444;
  white-space: nowrap;
  flex-shrink: 0;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  border-top: 2rpx solid #F3F4F6;
}

.fav-count {
  font-size: 24rpx;
  color: #6B7280;
}

.toolbar-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.edit-toggle {
  font-size: 26rpx;
  color: #0a5d7b;
  font-weight: 600;
}

.edit-toggle.active {
  color: #EF4444;
}

.select-all-btn {
  font-size: 26rpx;
  color: #0a5d7b;
}

.item-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.item-card {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: background-color 0.2s;
}

.item-card.selected {
  background-color: #EEF2FF;
}

.checkbox-area {
  display: flex;
  align-items: center;
  padding: 0 16rpx 0 20rpx;
  flex-shrink: 0;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #0a5d7b;
  border-color: #0a5d7b;
}

.check-mark {
  width: 16rpx;
  height: 16rpx;
  background: #FFFFFF;
  border-radius: 50%;
}

.item-body {
  flex: 1;
  display: flex;
  min-width: 0;
}

.item-image {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  background-color: #F3F4F6;
}

.item-content {
  flex: 1;
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
}

.item-content-text {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 6rpx;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-tags {
  margin-top: 6rpx;
}

.mini-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #4F46E5;
  background-color: #EEF2FF;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-right: 8rpx;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 6rpx;
}

.publisher-name {
  font-size: 22rpx;
  color: #9CA3AF;
}

.remove-btn {
  font-size: 24rpx;
  color: #9CA3AF;
  padding: 8rpx 16rpx;
}

.remove-btn:active {
  color: #EF4444;
}

.batch-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.batch-info {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
}

.batch-btn {
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  padding: 0 32rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  color: #9CA3AF;
  font-size: 28rpx;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E5E7EB;
  border-top-color: #0a5d7b;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
