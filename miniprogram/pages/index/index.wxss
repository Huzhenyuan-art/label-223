.post-tag {
  color: #0a5d7b;
  font-size: 26rpx;
  font-weight: 600;
}

.post-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.post-content {
  color: #2a4958;
}

.post-image {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
}

.action-row {
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 24rpx;
}

.hot-item {
  border-bottom: 1rpx solid #e0edf3;
  padding: 14rpx 0;
}

.hot-item:last-child {
  border-bottom: none;
}

.hot-rank {
  width: 80rpx;
  color: #0a6b8f;
  font-weight: 700;
}

.hot-tag {
  font-weight: 600;
}

.radar-wrap {
  position: relative;
  height: 420rpx;
  margin-bottom: 20rpx;
  border-radius: 18rpx;
  background: radial-gradient(circle at center, rgba(24, 111, 143, 0.12) 0%, rgba(24, 111, 143, 0.02) 72%);
  overflow: hidden;
}

.radar-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  border: 2rpx dashed rgba(13, 98, 130, 0.3);
  border-radius: 50%;
}

.ring-a {
  width: 320rpx;
  height: 320rpx;
}

.ring-b {
  width: 230rpx;
  height: 230rpx;
}

.ring-c {
  width: 140rpx;
  height: 140rpx;
}

.radar-core {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #0c6486;
  color: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.radar-dot {
  position: absolute;
  transform: translate(-50%, -50%);
}

.radar-text {
  background: #f4fbff;
  color: #0b698c;
  border: 1rpx solid #b8deef;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
}
