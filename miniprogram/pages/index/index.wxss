.post-tag {
  color: #0a5d7b;
  font-size: 26rpx;
  font-weight: 600;
}

.post-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.post-content {
  color: #2a4958;
}

.post-image {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
}

.action-row {
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 24rpx;
}

.hot-item {
  border-bottom: 1rpx solid #e0edf3;
  padding: 14rpx 0;
}

.hot-item:last-child {
  border-bottom: none;
}

.hot-rank {
  width: 80rpx;
  color: #0a6b8f;
  font-weight: 700;
}

.hot-tag {
  font-weight: 600;
}

.radar-wrap {
  position: relative;
  height: 420rpx;
  margin-bottom: 20rpx;
  border-radius: 18rpx;
  background: radial-gradient(circle at center, rgba(24, 111, 143, 0.12) 0%, rgba(24, 111, 143, 0.02) 72%);
  overflow: hidden;
}

.radar-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  border: 2rpx dashed rgba(13, 98, 130, 0.3);
  border-radius: 50%;
}

.ring-a {
  width: 320rpx;
  height: 320rpx;
}

.ring-b {
  width: 230rpx;
  height: 230rpx;
}

.ring-c {
  width: 140rpx;
  height: 140rpx;
}

.radar-core {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #0c6486;
  color: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.radar-dot {
  position: absolute;
  transform: translate(-50%, -50%);
}

.radar-text {
  background: #f4fbff;
  color: #0b698c;
  border: 1rpx solid #b8deef;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
}

.tag-shortcuts-card {
  background: linear-gradient(150deg, rgba(255, 255, 255, 0.98) 0%, rgba(242, 249, 253, 0.98) 100%);
  border: 2rpx solid rgba(129, 182, 206, 0.25);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(7, 56, 76, 0.08);
  padding: 20rpx 24rpx 12rpx;
  margin-bottom: 24rpx;
}

.shortcuts-header {
  margin-bottom: 16rpx;
}

.shortcuts-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #0d4f69;
}

.shortcuts-manage {
  font-size: 24rpx;
  color: #0a8ab5;
}

.shortcuts-scroll {
  width: 100%;
  white-space: nowrap;
}

.shortcuts-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 2rpx 12rpx;
}

.shortcut-chip {
  position: relative;
  display: inline-flex;
  align-items: center;
  background: #eaf5fb;
  border: 2rpx solid #b7d8e7;
  border-radius: 999rpx;
  padding: 12rpx 22rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.shortcut-chip.active {
  background: linear-gradient(135deg, #0b6585 0%, #0a8ab5 100%);
  border-color: #0a8ab5;
  box-shadow: 0 4rpx 12rpx rgba(11, 101, 133, 0.3);
}

.shortcut-chip.active .shortcut-name {
  color: #ffffff;
}

.shortcut-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #0f5977;
}

.shortcut-chip.add-btn {
  background: rgba(10, 138, 181, 0.08);
  border-style: dashed;
  border-color: rgba(10, 138, 181, 0.4);
}

.shortcut-chip.add-btn .shortcut-name {
  color: #0a8ab5;
  font-weight: 600;
}

.shortcut-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #ff4d4f;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 79, 0.4);
  line-height: 1;
  box-sizing: border-box;
}

.active-tag-indicator {
  background: rgba(10, 138, 181, 0.1);
  border: 2rpx solid rgba(10, 138, 181, 0.3);
  border-radius: 18rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.active-tag-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.active-tag-label {
  font-size: 24rpx;
  color: #6e8794;
}

.active-tag-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0a8ab5;
}

.active-tag-close {
  font-size: 24rpx;
  color: #0a8ab5;
  padding: 6rpx 18rpx;
  background: rgba(10, 138, 181, 0.12);
  border-radius: 999rpx;
}

.featured-posts {
  margin: 8rpx 0 16rpx 80rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(245, 251, 255, 0.9) 0%, rgba(230, 244, 252, 0.9) 100%);
  border: 1rpx solid rgba(129, 182, 206, 0.3);
  border-radius: 16rpx;
}

.featured-header {
  font-size: 22rpx;
  color: #0a6b8f;
  font-weight: 600;
  margin-bottom: 12rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx dashed rgba(129, 182, 206, 0.4);
}

.featured-post-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(129, 182, 206, 0.2);
}

.featured-post-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.featured-post-meta {
  margin-bottom: 6rpx;
}

.featured-post-tag {
  color: #0a5d7b;
  font-size: 22rpx;
  font-weight: 600;
}

.featured-post-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #0d4f69;
  margin-bottom: 4rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.featured-post-content {
  font-size: 24rpx;
  color: #2a4958;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
}

.featured-post-stats {
  margin-top: 8rpx;
}

.growth-badge {
  font-size: 20rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 53, 0.3);
}

.growth-badge.flat {
  background: rgba(129, 182, 206, 0.3);
  color: #5c7a89;
  box-shadow: none;
}
