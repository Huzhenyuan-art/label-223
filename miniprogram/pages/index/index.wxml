<view class="container">
  <view class="hero-card">
    <view class="hero-title">回声岛 · 海洋流</view>
    <view class="hero-subtitle">去身份化表达，让每一次观点都被认真听见。</view>
  </view>

  <view wx:if="{{subscribedTags.length}}" class="tag-shortcuts-card">
    <view class="row-between shortcuts-header">
      <view class="shortcuts-title">我的订阅频道</view>
      <view class="shortcuts-manage" bindtap="handleManageTags">管理 →</view>
    </view>
    <scroll-view class="shortcuts-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="shortcuts-inner">
        <block wx:for="{{subscribedTags}}" wx:key="tag">
          <view
            class="shortcut-chip {{activeTag === item.tag ? 'active' : ''}}"
            data-tag="{{item.tag}}"
            bindtap="handleTagClick"
          >
            <view class="shortcut-name">#{{item.displayName}}</view>
            <view wx:if="{{item.hasNewContent}}" class="shortcut-badge">
              {{item.unreadCount > 99 ? '99+' : (item.unreadCount > 0 ? item.unreadCount : 'NEW')}}
            </view>
          </view>
        </block>
        <view class="shortcut-chip add-btn" bindtap="handleManageTags">
          <view class="shortcut-name">+ 添加</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{activeTag}}" class="active-tag-indicator">
    <view class="active-tag-info">
      <text class="active-tag-label">当前频道：</text>
      <text class="active-tag-name">#{{activeTag}}</text>
    </view>
    <view class="active-tag-close" bindtap="handleModeChange" data-mode="recommend">
      切换回推荐
    </view>
  </view>

  <view class="ocean-card">
    <view class="wrap">
      <block wx:for="{{modes}}" wx:key="key">
        <view
          class="tag-chip {{activeMode === item.key ? 'active' : ''}}"
          data-mode="{{item.key}}"
          bindtap="handleModeChange"
        >
          {{item.label}}
        </view>
      </block>
    </view>

    <input
      class="input mt-12"
      placeholder="输入关键词，探索同频主题"
      value="{{keyword}}"
      bindinput="handleKeywordInput"
    />

    <input
      class="input mt-16"
      placeholder="输入标签，多个标签用逗号分隔"
      value="{{tagsInput}}"
      bindinput="handleTagsInput"
    />

    <button class="btn-secondary mt-16" bindtap="handleSearchApply">应用搜索条件</button>

    <view wx:if="{{preferredTags.length}}" class="mt-16 muted">推荐依据：{{preferredTags.join('、')}}</view>
  </view>

  <view wx:if="{{activeMode === 'hot' && hotTags.length}}" class="ocean-card">
    <view class="section-title">热点频率榜（每小时刷新）</view>
    <view class="radar-wrap">
      <view class="radar-ring ring-a"></view>
      <view class="radar-ring ring-b"></view>
      <view class="radar-ring ring-c"></view>
      <view class="radar-core">声纳</view>
      <block wx:for="{{radarTags}}" wx:key="tag">
        <view class="radar-dot" style="{{item.style}}">
          <text class="radar-text">#{{item.tag}}</text>
        </view>
      </block>
    </view>
    <block wx:for="{{hotTags}}" wx:key="tag">
      <view class="row-between hot-item">
        <view class="row">
          <view class="hot-rank">#{{item.rank}}</view>
          <view class="hot-tag">{{item.tag}}</view>
        </view>
        <view class="muted">热度 {{item.heat}}</view>
      </view>
      <view wx:if="{{item.featuredOriginPosts.length}}" class="featured-posts">
        <view class="featured-header">标签内精选原频 · 近1小时共鸣增速</view>
        <block wx:for="{{item.featuredOriginPosts}}" wx:for-item="post" wx:key="_id">
          <view class="featured-post-item" data-id="{{post._id}}" bindtap="goDetail">
            <view class="row-between featured-post-meta">
              <view class="featured-post-tag">{{post.dynamicTag}}</view>
              <view class="muted">{{post.timeAgo}}</view>
            </view>
            <view wx:if="{{post.title}}" class="featured-post-title">{{post.title}}</view>
            <view class="featured-post-content">{{post.contentText}}</view>
            <view class="row-between featured-post-stats">
              <view class="muted">共鸣 {{post.resonanceCount}} · 回声 {{post.commentCount}} · 合鸣 {{post.superEchoCount}}</view>
              <view class="growth-badge" wx:if="{{post.resonanceGrowth > 0}}">+{{post.resonanceGrowth}} 增速</view>
              <view class="growth-badge flat" wx:else>0 增速</view>
            </view>
          </view>
        </block>
      </view>
    </block>
  </view>

  <block wx:if="{{posts.length}}">
    <block wx:for="{{posts}}" wx:key="_id">
      <view class="ocean-card">
        <view class="row-between mb-16">
          <view class="post-tag">{{item.dynamicTag}}</view>
          <view class="muted">{{item.timeAgo}}</view>
        </view>

        <view wx:if="{{item.title}}" class="post-title">{{item.title}}</view>
        <view class="post-content">{{item.contentText}}</view>

        <image
          wx:if="{{item.coverImage}}"
          class="post-image mt-16"
          src="{{item.coverImage}}"
          mode="aspectFill"
        />

        <view class="wrap mt-16">
          <block wx:for="{{item.tags}}" wx:key="*this">
            <view class="tag-chip">#{{item}}</view>
          </block>
        </view>

        <view class="row-between mt-20">
          <view class="muted">共鸣 {{item.resonanceCount}} · 回声 {{item.commentCount}} · 合鸣 {{item.superEchoCount}}</view>
        </view>

        <view class="row mt-16 action-row">
          <button class="btn-secondary action-btn" data-id="{{item._id}}" bindtap="handleToggleResonance">
            {{item.isResonated ? '取消共鸣' : '共鸣'}}
          </button>
          <button class="btn-secondary action-btn" data-id="{{item._id}}" bindtap="handleToggleFavorite">
            {{item.isFavorited ? '取消收藏' : '收藏'}}
          </button>
          <button class="btn-primary action-btn" data-id="{{item._id}}" bindtap="goDetail">查看详情</button>
        </view>
      </view>
    </block>
  </block>

  <view wx:elif="{{!loading}}" class="empty">还没有符合条件的频率，试试更宽松的搜索。</view>

  <view wx:if="{{loading}}" class="empty">正在加载频率中...</view>
</view>
