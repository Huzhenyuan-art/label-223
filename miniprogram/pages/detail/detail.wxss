.post-tag {
  color: #0a5d7b;
  font-size: 26rpx;
  font-weight: 600;
}

.post-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.post-content {
  color: #2a4958;
}

.post-image {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
}

.audio-hint {
  color: #0a607f;
  font-size: 24rpx;
  word-break: break-all;
}

.action-row {
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
}

.tree-line {
  border-left: 4rpx solid #b5d6e5;
  padding-left: 16rpx;
  margin-bottom: 16rpx;
}

.tree-tag {
  font-size: 24rpx;
  color: #0c5f7f;
  font-weight: 600;
}

.tree-content {
  color: #345462;
  margin-top: 6rpx;
}

.comment-item {
  border-bottom: 1rpx solid #e0edf3;
  padding: 14rpx 0;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-content {
  margin-top: 6rpx;
}

.warn-text {
  color: #0f7399;
  font-size: 24rpx;
}

.edited-hint {
  font-size: 24rpx;
  font-style: italic;
}

.owner-actions {
  gap: 16rpx;
}

.edit-btn,
.delete-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
}

.resonance-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e0edf3;
}

.resonance-item:last-child {
  border-bottom: none;
}

.resonance-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #eaf5fb;
}

.resonance-info {
  flex: 1;
  min-width: 0;
}

.resonance-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1f3a48;
}

.resonance-time {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.load-more {
  text-align: center;
  padding: 20rpx 0;
  color: #0d4f69;
  font-size: 26rpx;
}

.no-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
}

.reply-action {
  margin-top: 12rpx;
  color: #0a5d7b;
  font-size: 24rpx;
  font-weight: 500;
}

.reply-list {
  margin-top: 16rpx;
  padding-left: 24rpx;
  border-left: 4rpx solid #d4e8f1;
}

.reply-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eef6fa;
}

.reply-item:last-child {
  border-bottom: none;
}

.reply-tag {
  font-size: 22rpx;
  color: #0c5f7f;
  font-weight: 600;
}

.reply-content {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #345462;
}

.reply-form {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f2f8fc;
  border-radius: 12rpx;
}

.reply-hint {
  font-size: 24rpx;
}

.reply-actions {
  gap: 12rpx;
}

.reply-cancel-btn,
.reply-submit-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
}
