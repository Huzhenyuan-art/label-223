.post-tag {
  color: #0a5d7b;
  font-size: 26rpx;
  font-weight: 600;
}

.post-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.post-content {
  color: #2a4958;
}

.post-image {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
}

.audio-hint {
  color: #0a607f;
  font-size: 24rpx;
  word-break: break-all;
}

.action-row {
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
}

.tree-line {
  border-left: 4rpx solid #b5d6e5;
  padding-left: 16rpx;
  margin-bottom: 16rpx;
}

.tree-tag {
  font-size: 24rpx;
  color: #0c5f7f;
  font-weight: 600;
}

.tree-content {
  color: #345462;
  margin-top: 6rpx;
}

.comment-item {
  border-bottom: 1rpx solid #e0edf3;
  padding: 14rpx 0;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-content {
  margin-top: 6rpx;
}

.warn-text {
  color: #0f7399;
  font-size: 24rpx;
}

.edited-hint {
  font-size: 24rpx;
  font-style: italic;
}

.owner-actions {
  gap: 16rpx;
}

.edit-btn,
.delete-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
}

.resonance-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e0edf3;
}

.resonance-item:last-child {
  border-bottom: none;
}

.resonance-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #eaf5fb;
}

.resonance-info {
  flex: 1;
  min-width: 0;
}

.resonance-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1f3a48;
}

.resonance-time {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.load-more {
  text-align: center;
  padding: 20rpx 0;
  color: #0d4f69;
  font-size: 26rpx;
}

.no-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
}

.reply-action {
  margin-top: 12rpx;
  color: #0a5d7b;
  font-size: 24rpx;
  font-weight: 500;
}

.reply-list {
  margin-top: 16rpx;
  padding-left: 24rpx;
  border-left: 4rpx solid #d4e8f1;
}

.reply-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eef6fa;
}

.reply-item:last-child {
  border-bottom: none;
}

.reply-tag {
  font-size: 22rpx;
  color: #0c5f7f;
  font-weight: 600;
}

.reply-content {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #345462;
}

.reply-form {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f2f8fc;
  border-radius: 12rpx;
}

.reply-hint {
  font-size: 24rpx;
}

.reply-actions {
  gap: 12rpx;
}

.reply-cancel-btn,
.reply-submit-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
}

.skin-card {
  position: relative;
  overflow: hidden;
}

.skin-card .post-tag {
  transition: color 0.3s;
}

.skin-card .tag-chip {
  transition: all 0.3s;
}

.skin-ocean .post-tag {
  color: #0a5d7b;
}

.skin-ocean .tag-chip {
  background: #eaf5fb;
  color: #0f5977;
  border-color: #b7d8e7;
}

.skin-sunset .post-tag {
  color: #b83e1e;
}

.skin-sunset .tag-chip {
  background: #fef0e8;
  color: #c44e2b;
  border-color: #f5c4a8;
}

.skin-sunset {
  background: linear-gradient(150deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 243, 235, 0.98) 100%);
  border-color: rgba(245, 170, 130, 0.3);
}

.skin-mint .post-tag {
  color: #1a7a5a;
}

.skin-mint .tag-chip {
  background: #e8f8f0;
  color: #1e8a60;
  border-color: #a8debb;
}

.skin-mint {
  background: linear-gradient(150deg, rgba(255, 255, 255, 0.98) 0%, rgba(235, 250, 242, 0.98) 100%);
  border-color: rgba(140, 210, 170, 0.3);
}

.skin-ink .post-tag {
  color: #e0d8c8;
}

.skin-ink .tag-chip {
  background: #2a2520;
  color: #d4cabb;
  border-color: #4a4035;
}

.skin-ink {
  background: linear-gradient(150deg, rgba(30, 28, 25, 0.98) 0%, rgba(45, 40, 35, 0.98) 100%);
  border-color: rgba(80, 70, 60, 0.4);
  color: #d4cabb;
}

.skin-ink .post-title {
  color: #e8e0d4;
}

.skin-ink .post-content {
  color: #c4baa8;
}

.skin-ink .muted {
  color: #8a7e6e;
}

.skin-locked {
  filter: grayscale(0.85) opacity(0.7);
}

.skin-locked .skin-lock-overlay {
  display: flex;
}

.skin-lock-overlay {
  display: none;
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.55));
  padding: 28rpx 24rpx 20rpx;
  align-items: center;
  justify-content: space-between;
  z-index: 2;
}

.skin-lock-hint {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
}

.skin-lock-btn {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #0b6585 0%, #0a8ab5 100%);
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
}
