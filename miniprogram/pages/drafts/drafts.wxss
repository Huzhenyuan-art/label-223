.clear-all-btn {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
}

.clear-all-btn:active {
  background: rgba(255, 255, 255, 0.35);
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #0f5977;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #6e8794;
  line-height: 1.7;
}

.draft-card {
  position: relative;
  background: linear-gradient(150deg, rgba(255, 255, 255, 0.98) 0%, rgba(242, 249, 253, 0.98) 100%);
  border: 2rpx solid rgba(129, 182, 206, 0.25);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(7, 56, 76, 0.06);
  padding: 24rpx;
  margin-bottom: 20rpx;
  transition: all 0.2s ease;
}

.draft-card.active {
  border-color: #0c5f7f;
  box-shadow: 0 12rpx 28rpx rgba(12, 95, 127, 0.18);
}

.draft-card:active {
  transform: scale(0.99);
}

.draft-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.draft-tag {
  display: inline-block;
  background: #e5f4fb;
  color: #0c5f7f;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.draft-time {
  font-size: 22rpx;
}

.draft-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f3a48;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.draft-summary {
  font-size: 26rpx;
  color: #5a7684;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.draft-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
}

.meta-badge {
  padding: 6rpx 16rpx;
  background: #eef6fa;
  color: #5a7684;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.meta-badge.created {
  background: transparent;
  color: #98b3c0;
  padding: 6rpx 0;
}

.action-popup {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 20rpx 60rpx rgba(7, 56, 76, 0.3);
  min-width: 360rpx;
  overflow: hidden;
  z-index: 10;
  border: 2rpx solid #d7e9f1;
}

.action-popup-item {
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  text-align: center;
  border-bottom: 2rpx solid #eef6fa;
  color: #1f3a48;
}

.action-popup-item:last-child {
  border-bottom: none;
}

.action-popup-item.primary {
  color: #0c5f7f;
  font-weight: 600;
  background: #f4fbfd;
}

.action-popup-item.danger {
  color: #e74c3c;
}

.action-popup-item.cancel {
  color: #6e8794;
  background: #f6fafd;
}

.action-popup-item:active {
  background: #eef6fa;
}

.tip-card {
  text-align: center;
  padding: 32rpx 24rpx;
  font-size: 24rpx;
}
