.channel-header {
  background: linear-gradient(135deg, #0d3c52 0%, #0b5770 55%, #3b8fb0 100%);
  color: #eaf8ff;
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 20rpx 40rpx rgba(13, 60, 82, 0.22);
}

.channel-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.channel-title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.channel-desc {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.channel-stats {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  opacity: 0.85;
}

.stat-item {
  padding: 0 8rpx;
}

.stat-divider {
  opacity: 0.5;
  padding: 0 8rpx;
}

.channel-action .btn-primary,
.channel-action .btn-secondary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
}

.channel-action .btn-secondary {
  background: rgba(255, 255, 255, 0.15);
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.post-tag {
  color: #0a5d7b;
  font-size: 26rpx;
  font-weight: 600;
}

.post-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.post-content {
  color: #2a4958;
}

.post-image {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
}

.action-row {
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 24rpx;
}
