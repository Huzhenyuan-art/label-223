<view class="container">
  <view class="channel-header">
    <view class="channel-title-row">
      <view class="channel-title">#{{displayName || tag}}</view>
    </view>
    <view wx:if="{{description}}" class="channel-desc">{{description}}</view>
    <view class="channel-stats">
      <text class="stat-item">{{subscriberCount}} 订阅</text>
      <text class="stat-divider">·</text>
      <text class="stat-item">{{postCount}} 原频</text>
    </view>
    <view class="channel-action">
      <button
        wx:if="{{!isSubscribed}}"
        class="btn-primary"
        bindtap="handleSubscribe"
      >
        订阅频道
      </button>
      <button
        wx:else
        class="btn-secondary"
        bindtap="handleUnsubscribe"
      >
        已订阅
      </button>
    </view>
  </view>

  <block wx:if="{{posts.length}}">
    <block wx:for="{{posts}}" wx:key="_id">
      <view class="ocean-card">
        <view class="row-between mb-16">
          <view class="post-tag">{{item.dynamicTag}}</view>
          <view class="muted">{{item.timeAgo}}</view>
        </view>

        <view wx:if="{{item.title}}" class="post-title">{{item.title}}</view>
        <view class="post-content">{{item.contentText}}</view>

        <image
          wx:if="{{item.coverImage}}"
          class="post-image mt-16"
          src="{{item.coverImage}}"
          mode="aspectFill"
        />

        <view class="wrap mt-16">
          <block wx:for="{{item.tags}}" wx:key="*this">
            <view class="tag-chip">#{{item}}</view>
          </block>
        </view>

        <view class="row-between mt-20">
          <view class="muted">共鸣 {{item.resonanceCount}} · 回声 {{item.commentCount}} · 合鸣 {{item.superEchoCount}}</view>
        </view>

        <view class="row mt-16 action-row">
          <button class="btn-secondary action-btn" data-id="{{item._id}}" bindtap="handleToggleResonance">
            {{item.isResonated ? '取消共鸣' : '共鸣'}}
          </button>
          <button class="btn-secondary action-btn" data-id="{{item._id}}" bindtap="handleToggleFavorite">
            {{item.isFavorited ? '取消收藏' : '收藏'}}
          </button>
          <button class="btn-primary action-btn" data-id="{{item._id}}" bindtap="goDetail">查看详情</button>
        </view>
      </view>
    </block>
  </block>

  <view wx:elif="{{!loading}}" class="empty">该标签下还没有原频，成为第一个发声的人吧~</view>

  <view wx:if="{{loading}}" class="empty">正在加载频率中...</view>
</view>
