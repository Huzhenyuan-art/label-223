.premium-badge {
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 22rpx;
}

.interest-bubble {
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eaf6fb;
  color: #0a6385;
  border: 1rpx solid #bcdce9;
}

.favorite-group {
  margin-bottom: 18rpx;
}

.favorite-title {
  font-size: 28rpx;
  color: #0b6281;
  margin-bottom: 10rpx;
  font-weight: 600;
}

.favorite-post {
  border: 1rpx solid #d9eaf2;
  border-radius: 12rpx;
  padding: 12rpx;
  margin-bottom: 10rpx;
}

.favorite-post-title,
.my-post-title {
  font-weight: 600;
}

.my-post {
  border-bottom: 1rpx solid #e0edf3;
  padding: 14rpx 0;
}

.my-post:last-child {
  border-bottom: none;
}

.mini-btn {
  width: 180rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.section-title-flex {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.actions-row {
  flex-shrink: 0;
}

.action-btn-gap {
  margin-left: 12rpx;
}

.actions-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-cell {
  flex: 1;
  min-width: 0;
}

.action-grid-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 24rpx;
}

.login-state-card {
  margin-top: 12rpx;
}

.notify-badge-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.notify-badge {
  background: #e74c3c;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 999rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  padding: 0 10rpx;
  margin-right: 10rpx;
}

.notify-item {
  padding: 16rpx;
  border: 1rpx solid #d9eaf2;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.notify-unread {
  border-left: 6rpx solid #0a5d7b;
  background: #f0f8fc;
}

.notify-sender {
  font-weight: 600;
  color: #1f3a48;
  font-size: 28rpx;
}

.notify-time {
  font-size: 22rpx;
}

.notify-content {
  color: #345462;
  margin-top: 8rpx;
  font-size: 26rpx;
}

.notify-post-hint {
  color: #0a5d7b;
  font-size: 24rpx;
  margin-top: 6rpx;
}

.mark-all-btn {
  color: #0a5d7b;
  font-size: 24rpx;
  font-weight: 500;
}
