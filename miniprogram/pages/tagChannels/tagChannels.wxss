.tabs {
  display: flex;
  background: #ffffff;
  border-radius: 18rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 56, 76, 0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #6e8794;
  transition: all 0.2s;
}

.tab-item.active {
  background: linear-gradient(135deg, #0b6585 0%, #0a8ab5 100%);
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(11, 101, 133, 0.3);
}

.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  align-items: center;
}

.search-btn {
  width: 160rpx;
  height: 86rpx;
  line-height: 86rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}

.tag-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.tag-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(129, 182, 206, 0.2);
  box-shadow: 0 4rpx 16rpx rgba(7, 56, 76, 0.06);
}

.tag-card-header {
  margin-bottom: 16rpx;
}

.tag-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0d4f69;
  margin-bottom: 6rpx;
}

.tag-reason {
  font-size: 22rpx;
  color: #0a8ab5;
  background: rgba(10, 138, 181, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  display: inline-block;
}

.tag-card-stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.tag-card-stats .stat {
  font-size: 22rpx;
  color: #6e8794;
}

.tag-card-action {
  width: 100%;
}

.tag-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tag-list-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(129, 182, 206, 0.2);
  box-shadow: 0 4rpx 16rpx rgba(7, 56, 76, 0.06);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.tag-list-main {
  flex: 1;
  min-width: 0;
}

.tag-list-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.tag-list-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0d4f69;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.official-tag {
  font-size: 20rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #e8a33d, #f0c041);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

.new-badge {
  font-size: 22rpx;
  color: #ffffff;
  background: #ff4d4f;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 600;
  min-width: 36rpx;
  text-align: center;
  flex-shrink: 0;
}

.tag-list-desc {
  font-size: 24rpx;
  color: #6e8794;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag-list-stats {
  display: flex;
  gap: 24rpx;
}

.tag-list-stats .stat {
  font-size: 22rpx;
  color: #6e8794;
}

.tag-list-action {
  flex-shrink: 0;
}

.btn-sm {
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  padding: 0 28rpx;
  min-width: 140rpx;
}
