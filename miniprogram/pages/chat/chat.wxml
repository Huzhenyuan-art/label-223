<view class="container">
  <view class="ocean-card">
    <view class="row-between">
      <view class="chat-name" bindtap="openTempNicknameModal">{{displayName}}<text wx:if="{{reveal && !reveal.revealed}}" class="edit-icon"> ✎</text></view>
      <view class="chat-state">{{reveal && reveal.revealed ? '身份已揭示' : '动态标签对话中'}} {{!wsConnected ? '(连接中…)' : ''}}</view>
    </view>

    <view wx:if="{{reveal && !reveal.revealed && !reveal.waitingForOther && !reveal.otherRequestedReveal}}" class="mt-12 muted">
      你 {{reveal.myCount || 0}} 条，对方 {{reveal.otherCount || 0}} 条。双方≥3条可申请揭示。
    </view>

    <view wx:if="{{reveal && reveal.waitingForOther}}" class="reveal-waiting mt-12">
      <view class="waiting-text">已申请揭示，等待对方回应…</view>
      <view wx:if="{{autoRevealCountdown}}" class="waiting-countdown">对方 {{autoRevealCountdown}} 内未响应将自动视为同意</view>
    </view>

    <view wx:if="{{reveal && reveal.otherRequestedReveal}}" class="reveal-requested mt-12">
      <view class="requested-text">对方已申请揭示身份</view>
      <button class="btn-secondary mt-8" bindtap="requestReveal">同意揭示</button>
    </view>

    <view wx:if="{{myTempNickname && !reveal.revealed}}" class="mt-8 muted">
      我的临时昵称：{{myTempNickname}}
    </view>

    <button
      wx:if="{{reveal && reveal.eligible && !reveal.revealed && !reveal.myAgreed}}"
      class="btn-secondary mt-16"
      bindtap="requestReveal"
    >
      申请揭示身份
    </button>

    <button
      wx:if="{{reveal && !reveal.revealed}}"
      class="btn-outline mt-12"
      bindtap="openTempNicknameModal"
    >
      {{myTempNickname ? '修改临时昵称' : '设置本轮临时昵称'}}
    </button>

    <button
      wx:if="{{reveal && reveal.revealed}}"
      class="btn-secondary mt-16"
      bindtap="openPublicProfile"
    >
      查看对方主页
    </button>
  </view>

  <scroll-view class="chat-scroll" scroll-y="true" scroll-with-animation="true" scroll-into-view="{{scrollAnchor}}">
    <block wx:for="{{list}}" wx:key="_id">
      <view id="msg-{{item._id}}" class="msg-row {{item.mine ? 'mine' : 'other'}}">
        <view class="msg-bubble">
          <view class="msg-tag">{{item.senderDynamicTag}}</view>
          <view wx:if="{{item.sourcePostLabel}}" class="msg-source">来自频率：{{item.sourcePostLabel}}</view>
          <view class="msg-content">{{item.content}}</view>
          <view class="msg-time">{{item.timeAgo}} <text wx:if="{{item.mine}}" class="msg-read-status">{{item.read ? '已读' : '未读'}}</text></view>
        </view>
      </view>
    </block>

    <view wx:if="{{!list.length && !loading}}" class="empty">还没有消息，发出第一条海浪吧。</view>
  </scroll-view>

  <view class="input-bar">
    <input class="input mb-12" placeholder="发送身份标签" value="{{senderDynamicTag}}" data-key="senderDynamicTag" bindinput="bindField" />
    <view class="row">
      <input class="input flex-1" placeholder="输入消息内容" value="{{content}}" data-key="content" bindinput="bindField" />
      <button class="btn-primary send-btn" bindtap="sendMessage">发送</button>
    </view>
  </view>

  <view wx:if="{{showTempNicknameModal}}" class="modal-mask" bindtap="closeTempNicknameModal">
    <view class="modal-content" catchtap="">
      <view class="modal-title">设置本轮临时昵称</view>
      <view class="modal-desc">对方在揭示身份前会看到这个昵称，而非「同频回声」</view>
      <input
        class="modal-input"
        placeholder="请输入临时昵称（最多24字）"
        value="{{tempNicknameInput}}"
        maxlength="24"
        bindinput="bindTempNicknameInput"
        focus="{{showTempNicknameModal}}"
      />
      <view class="modal-actions">
        <button class="btn-outline modal-btn" bindtap="closeTempNicknameModal">取消</button>
        <button class="btn-primary modal-btn" bindtap="confirmTempNickname">确定</button>
      </view>
    </view>
  </view>
</view>
