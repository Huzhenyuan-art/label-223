.chat-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0a5f7e;
}

.chat-state {
  color: #0a7398;
  font-size: 24rpx;
}

.chat-scroll {
  height: 58vh;
  margin-bottom: 16rpx;
}

.msg-row {
  display: flex;
  margin-bottom: 16rpx;
}

.msg-row.mine {
  justify-content: flex-end;
}

.msg-row.other {
  justify-content: flex-start;
}

.msg-bubble {
  max-width: 78%;
  background: #ffffff;
  border: 2rpx solid #d4e7f0;
  border-radius: 16rpx;
  padding: 14rpx;
}

.msg-row.mine .msg-bubble {
  background: #e8f6fc;
  border-color: #b4d8e8;
}

.msg-tag {
  font-size: 22rpx;
  color: #0d5d7a;
  font-weight: 600;
}

.msg-content {
  margin-top: 4rpx;
  word-break: break-all;
}

.msg-source {
  margin-top: 4rpx;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  background: #f0f8fc;
  color: #0a688b;
  font-size: 21rpx;
}

.msg-time {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #7a95a2;
  text-align: right;
}

.msg-read-status {
  margin-left: 8rpx;
  font-size: 18rpx;
}

.msg-row.mine .msg-read-status {
  color: #0d8ab5;
}

.input-bar {
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid #d5e8f1;
  border-radius: 18rpx;
  padding: 14rpx;
}

.send-btn {
  width: 160rpx;
  margin-left: 12rpx;
  height: 82rpx;
  line-height: 82rpx;
}

.flex-1 {
  flex: 1;
}

.mb-12 {
  margin-bottom: 12rpx;
}

.mt-8 {
  margin-top: 8rpx;
}

.edit-icon {
  font-size: 24rpx;
  color: #0a7398;
  margin-left: 6rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0a5f7e;
  text-align: center;
  margin-bottom: 12rpx;
}

.modal-desc {
  font-size: 24rpx;
  color: #7a95a2;
  text-align: center;
  margin-bottom: 28rpx;
  line-height: 1.5;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #d5e8f1;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #0a3d52;
  background: #f8fcfe;
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.reveal-waiting {
  background: #f0f8fc;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  border: 2rpx solid #c4dfe9;
}

.waiting-text {
  color: #0d5d7a;
  font-size: 26rpx;
  font-weight: 600;
}

.waiting-countdown {
  color: #6e8794;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.reveal-requested {
  background: #eef6fa;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  border: 2rpx solid #b4d8e8;
}

.requested-text {
  color: #0a5f7e;
  font-size: 26rpx;
  font-weight: 600;
}
