.container {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.header {
  margin-bottom: 24rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0d5876;
}

.read-all {
  font-size: 26rpx;
  color: #0d6587;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(13, 101, 135, 0.1);
}

.subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #6e8794;
}

.tabs {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.tabs-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.tab-item {
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: #ffffff;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #6e8794;
  box-shadow: 0 2rpx 12rpx rgba(12, 42, 58, 0.06);
}

.tab-item.active {
  background: #0d6587;
  color: #ffffff;
  font-weight: 600;
}

.tab-dot {
  margin-left: 8rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff6b6b;
  color: #ffffff;
  font-size: 20rpx;
  text-align: center;
}

.tab-item.active .tab-dot {
  background: rgba(255, 255, 255, 0.3);
}

.notification-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: opacity 0.2s;
}

.notification-card.unread {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
}

.notification-icon {
  flex-shrink: 0;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e0f2fe;
}

.icon-resonance {
  background: linear-gradient(135deg, #ffe4e6 0%, #fecdd3 100%);
}

.icon-comment {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
}

.icon-super_echo {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
}

.icon-reveal {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
}

.icon-default {
  background: linear-gradient(135deg, #f3e8ff 0%, #e9d5ff 100%);
}

.icon-inner {
  font-size: 36rpx;
}

.notification-content {
  flex: 1;
  min-width: 0;
}

.notification-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0d5876;
  line-height: 1.4;
}

.notification-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #365260;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.notification-time {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #6e8794;
}

.unread-dot {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #0d6587;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #6e8794;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #6e8794;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
}
