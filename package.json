{
  "name": "echo-island",
  "version": "1.0.0",
  "private": true,
  "description": "Echo Island social resonance mini program - full stack project",
  "scripts": {
    "dev": "node scripts/run-dev.js",
    "start": "node scripts/run-dev.js",
    "env:check": "cd backend && npm run env:check",
    "health:check": "cd backend && npm run health:check",
    "seed": "cd backend && npm run seed",
    "test": "cd backend && npm run test",
    "test:unit": "cd backend && npm run test:unit",
    "test:integration": "cd backend && npm run test:integration",
    "test:coverage": "cd backend && npm run test:coverage",
    "docker:up": "docker compose up --build",
    "docker:up:detach": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:restart": "docker compose restart"
  },
  "engines": {
    "node": ">=18.17.0 <21",
    "npm": ">=9"
  }
}
