COMPOSE_PROJECT_NAME=echo-island

NODE_ENV=development
LOG_LEVEL=info

PORT=8223
MONGO_URI=mongodb://localhost:27223/echo_island
WS_PATH=/ws

JWT_SECRET=echo-island-dev-secret-change-me-please
JWT_EXPIRES_IN=7d

STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads
LOCAL_PUBLIC_BASE_URL=http://localhost:8223/uploads

MAX_IMAGE_SIZE=10485760
MAX_AUDIO_SIZE=52428800

RECOMMENDATION_ENABLED=true
RECOMMENDATION_FALLBACK=true
RECOMMENDATION_SCHEDULER_ENABLED=true
TAG_PRECOMPUTE_CRON=*/30 * * * *
HOT_SNAPSHOT_CRON=*/15 * * * *
CACHE_CLEANUP_CRON=0 * * * *
